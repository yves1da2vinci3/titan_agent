{
  "name": "titan-agent",
  "version": "1.0.0",
  "description": "Agent conversationnel de support Titan Telecom (T-BOX / T-MOBILE)",
  "main": "dist/index.js",
  "type": "module", 
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "node --max-old-space-size=4096 ./node_modules/typescript/bin/tsc",
    "typecheck": "node --max-old-space-size=4096 ./node_modules/typescript/bin/tsc --noEmit",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@langchain/anthropic": "^0.3.20",
    "@langchain/core": "^0.3.58",
    "@langchain/redis": "^0.1.0",
    "dotenv": "^16.5.0",
    "express": "^4.21.2",
    "langchain": "^0.3.27",
    "redis": "^4.7.0",
    "socket.io": "^4.8.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.17.30",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.8.3"
  }
}
