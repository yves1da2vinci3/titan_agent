PORT=3001
ANTHROPIC_API_KEY=sk-ant-...
REDIS_URL=redis://localhost:6379
TICKET_QUEUE_KEY=titan:tickets:queue
SESSION_TTL_SECONDS=1800
CHANNEL=chatbot

# Ticket system integration
# TICKET_SYSTEM_SECRET doit être identique à INTERNAL_SECRET du service ticketSystem (même valeur, même fichier .env local si besoin).
TICKET_SYSTEM_URL=http://localhost:8081
TICKET_SYSTEM_SECRET=your-ticket-system-secret

# Server integration (conversation persistence)
SERVER_URL=http://localhost:8080
AGENT_INTERNAL_SECRET=your-agent-secret

# RAG (PostgreSQL + Voyage — même base et même modèle que le server)
# DATABASE_URL=postgresql://titan:titan@localhost:5432/titan_db
# VOYAGE_API_KEY=
# VOYAGE_EMBEDDING_MODEL=voyage-3.5
# KB_VECTOR_DIMENSIONS=1024
