{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext", // Crucial pour LangGraph
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true, // Garde ça, c'est ton bouclier anti-bourbier
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    // Supprime la section "paths" pour @langchain/langgraph/prebuilt, 
    // avec NodeNext, TypeScript le trouvera tout seul.
    "incremental": false
  },
  "ts-node": {
    "esm": true,
    "experimentalSpecifierResolution": "node",
    "transpileOnly": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}